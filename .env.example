# =====================================================================
# Neo4j
# =====================================================================
# Локальный dev (backend на хосте) -> bolt://localhost:7687
# Полный docker-compose -> значение перебивается на bolt://neo4j:7687
# в docker-compose.yml автоматически.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# =====================================================================
# LLM provider
# =====================================================================
# "groq"   — облачный Groq API (быстро, но данные уходят к провайдеру)
# "ollama" — локальный контейнер Ollama (данные не покидают контур)
LLM_PROVIDER=groq

# --- Groq ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama ---
# Для локального backend на хосте — http://localhost:11434/v1.
# В docker-compose значение перебивается на http://ollama:11434/v1 для контейнера backend.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Альтернативы по качеству/размеру: qwen2.5:7b, llama3.2:3b
OLLAMA_MODEL=llama3.1:8b

# =====================================================================
# Extraction
# =====================================================================
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
MAX_RETRIES=3
EXTRACTION_TEMPERATURE=0.1

# =====================================================================
# QA
# =====================================================================
QA_TEMPERATURE=0.0
QA_MAX_TOKENS=1024
CYPHER_FALLBACK_ENABLED=true

# =====================================================================
# Normalization
# =====================================================================
SIMILARITY_THRESHOLD=0.85

# =====================================================================
# CORS
# =====================================================================
# Список origin'ов через JSON. Локально достаточно дефолта в коде.
# На проде укажите домен фронта, например:
# ALLOWED_ORIGINS=["https://anagraph.example.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]
